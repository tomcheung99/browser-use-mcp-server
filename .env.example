# Path to Chrome/Chromium executable leave blank to use default playwright chromium
CHROME_PATH=

# LLM Configuration (defaults to Vercel AI Gateway + Qwen 3.5 Flash)
LLM_API_KEY=your-vercel-api-key
LLM_BASE_URL=https://api.vercel.ai/v1
LLM_MODEL=alibaba/qwen3.5-flash
LLM_TEMPERATURE=0.0

# Legacy OpenAI API key (used as fallback if LLM_API_KEY is not set)
# OPENAI_API_KEY=

# Set to true if you want api calls to wait for tasks to complete (default is false)
PATIENT=false

# Set to true if you want to disable anonymous telemetry (default is false)
ANONYMIZED_TELEMETRY=false